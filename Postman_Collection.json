		{
			"name": "🧪 Integration Test Scenarios",
			"item": [
				{
					"name": "Complete Transaction Flow",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Store transaction ID for later use",
									"const txnId = 'txn_flow_' + Date.now();",
									"pm.environment.set('currentTxnId', txnId);",
									"console.log('Generated transaction ID:', txnId);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"txnId\": \"{{currentTxnId}}\",\n  \"amount\": 150.75,\n  \"senderId\": 1,\n  \"recipientId\": 2\n}"
						},
						"url": {
							"raw": "http://localhost:8080/kafka/send",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"kafka",
								"send"
							]
						},
						"description": "Step 1: Send transaction to Kafka"
					},
					"response": []
				},
				{
					"name": "Verify Balance Update",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Wait for transaction processing",
									"setTimeout(function() {",
									"    pm.test('Balance should be updated', function() {",
									"        pm.sendRequest({",
									"            url: 'http://localhost:33400/balance?userId=1',",
									"            method: 'GET'",
									"        }, function (err, res) {",
									"            if (err) {",
									"                console.log('Error checking balance:', err);",
									"            } else {",
									"                const balance = res.json().balance;",
									"                console.log('Sender balance:', balance);",
									"            }",
									"        });",
									"    });",
									"}, 2000);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:33400/balance?userId=1",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "33400",
							"path": [
								"balance"
							],
							"query": [
								{
									"key": "userId",
									"value": "1"
								}
							]
						},
						"description": "Step 2: Check sender balance after transaction"
					},
					"response": []
				},
				{
					"name": "Verify Transaction Record",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:33400/api/incentives/1",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "33400",
							"path": [
								"api",
								"incentives",
								"1"
							]
						},
						"description": "Step 3: Verify transaction was recorded with incentive"
					},
					"response": []
				}
			],
			"description": "End-to-end integration test scenarios"
